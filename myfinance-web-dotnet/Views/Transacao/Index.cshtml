@{
    ViewData["Title"] = "Transações Financeiras";
}

<h1>@ViewData["Title"]</h1>
<button type="button" class="btn btn-block btn-primary" onclick="Novo()">Registrar Transação</button>
<br>
<br>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Histórico</th>
            <th>Tipo</th>
            <th>Valor</th>
            <th>Data</th>
            <th>#</th>
            <th>#</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in (List<TransacaoModel>)ViewBag.ListaTransacoes)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Historico</td>
                <td>@item.Tipo</td>
                <td>@item.Valor</td>
                <td>@item.Data</td>
                <td><button type="button" class="btn btn-block btn-outline-warning" onclick="Atualizar(@item.Id.ToString())">Editar</button></td>
                <td><button type="button" class="btn btn-block btn-outline-danger" onclick="Excluir(@item.Id.ToString())">Excluir</button></td>
            </tr>
        }
    </tbody>
</table>
    <script>
        function Novo(){
            window.location.href = '/PlanoConta/Cadastrar';
        }
        function Atualizar(id) {
            window.location.href = '/PlanoConta/Cadastrar/' + id;
        }
        function Excluir(id) {
            window.location.href = '/PlanoConta/Excluir/' + id;
        }
    </script>