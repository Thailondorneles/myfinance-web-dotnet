@model myfinance_web_dotnet.Models.TransacaoModel

@{
    ViewData["Title"] = "Registrar Transações Financeiras";
}

<h1>@ViewData["Title"]</h1>

<div>
    <form asp-controller="Transacao" asp-action="Cadastrar" method="post">
        <input type="hidden" asp-for="Id"/><br>

        <div class="form-group">
            <label>Data:</label>
            <input type="date" asp-for="Data" class="form-control"/>
        </div>

        <div class="form-group">
            <label>Valor:</label>
            <input type="text" asp-for="Valor" class="form-control" step="0.01"/>
        </div>

        <div class="form-group">
            <label>Plano de Contas:</label>
            @Html.DropDownListFor(m=> m.PlanoContaId, Model.ListaPlanoContas, new { @class = "form-select" })
        </div>

        <div class="form-group">
            <label>Histórico:</label>
            <input type="text" asp-for="Historico" class="form-control"/>
        </div>

        <br><br>
        <button type="submit" class="btn btn-block btn-success">Registrar</button>
    </form>
</div>